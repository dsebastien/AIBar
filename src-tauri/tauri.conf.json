{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "AIBar",
    "version": "0.1.0",
    "identifier": "com.aibar.app",
    "build": {
        "beforeDevCommand": "bun run dev",
        "beforeBuildCommand": "bun run build",
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420"
    },
    "app": {
        "windows": [
            {
                "width": 400,
                "height": 600,
                "minHeight": 400,
                "minWidth": 320,
                "dragDropEnabled": false,
                "fullscreen": false,
                "label": "main",
                "title": "AIBar",
                "url": "/",
                "visible": false,
                "decorations": false,
                "alwaysOnTop": true,
                "resizable": false,
                "skipTaskbar": true
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": {
                    "allow": ["**"],
                    "requireLiteralLeadingDot": false
                }
            }
        },
        "trayIcon": {
            "iconPath": "icons/icon.png",
            "tooltip": "AIBar - AI Usage Monitor",
            "iconAsTemplate": true
        }
    },
    "bundle": {
        "active": true,
        "createUpdaterArtifacts": true,
        "targets": ["nsis", "appimage", "deb"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.ico"
        ],
        "linux": {
            "appimage": {
                "bundleMediaFramework": false
            }
        },
        "windows": {
            "nsis": {
                "installMode": "currentUser"
            }
        }
    },
    "plugins": {
        "process": {
            "active": true
        },
        "updater": {
            "active": true
        }
    }
}
